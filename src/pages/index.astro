---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${base}${path.replace(/^\/+/, '')}`;

const heroImage = {
  src: withBase('/client-home/homepage-hero-image.jpg'),
  alt: 'Evening view of a mixed-use retail village with illuminated architecture',
};

const gastownImage = {
  src: withBase('/client-home/coldwell-building.jpeg'),
  alt: 'Coldwell Building streetscape in Gastown, Vancouver',
};

const leadershipImage = {
  src: withBase('/client-home/leadership-group.jpeg'),
  alt: 'collabor8 leadership group portrait against a brick wall',
};

const heroWords = ['Imagine', 'Create', 'Deliver'];

const moveNotice = {
  title: 'We Are Moving!',
  intro:
    'collabor8 Architecture + Design (BC) is moving locations. We are saying goodbye to the Marine Building and are very excited for our new space in the Coldwell Building in the heart of the historic Gastown area of downtown Vancouver.',
  date: 'Anticipated opening is May 15th, 2026!',
  detail:
    'Until we see you at our new premises, we continue working remotely and can be reached via our regular coordinates by phone, email or Zoom.',
};

const pillars = [
  {
    title: 'Imagine',
    lead: 'Inspiration is everywhere.',
    copy: 'In our environment, our imagination, our team, and our clients.',
  },
  {
    title: 'Create',
    lead: 'Creativity dwells in necessity.',
    copy: 'It springs from the nuances between function and design.',
  },
  {
    title: 'Deliver',
    lead: 'From sketch to realized building.',
    copy: 'Beautifully designed, exceptionally functional, and financially viable.',
  },
];

const leadership = [
  {
    name: 'Chris Block',
    role: 'Principal',
    copy:
      'provides leadership, oversight and strategic guidance. With over 30 years of experience across British Columbia and Alberta, he has extensive expertise navigating approval processes, including rezonings, development permits, and variances across a wide range of project types.',
  },
  {
    name: 'Andre Belliveau',
    role: 'Associates',
    copy:
      'is a senior project manager with experience delivering residential high-rise, mixed-use, and commercial projects across Western Canada. He brings strong technical knowledge and a practical approach to problem-solving, supporting the advancement of projects from early concept through to implementation.',
  },
  {
    name: 'Jordan Levine',
    role: '',
    copy:
      'advances leadership and strategic direction for both operations and design. He is responsible for guiding the team and coordinating stakeholders to balance design quality, functionality, budget, and schedule. He has been instrumental in the development of the Design Library concept and brings extensive experience across commercial and residential projects throughout British Columbia and Western Canada.',
  },
];

---

<Layout
  title="collabor8 Architecture + Design (BC)"
  description="Temporary collabor8 Architecture + Design (BC) homepage with move announcement, studio story, leadership, and recent projects."
>
  <Header page="home" />

  <main>
    <section class="hero" id="home">
      <div class="hero__media">
        <img
          class="hero__image"
          src={heroImage.src}
          alt={heroImage.alt}
          width="3000"
          height="2045"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          referrerpolicy="no-referrer"
          sizes="100vw"
        />
      </div>
      <div class="hero__brand-bar">
        <div class="hero__brand-lockup">
          <span class="hero__brand-name">collabor8</span>
          <span class="hero__brand-subtitle">Architecture + Design (BC)</span>
        </div>
      </div>
      <div class="hero__overlay">
        <div class="hero__panel">
          <h1 class="hero__title">
            {heroWords.map((word) => (
              <span class="hero__word" aria-label={word}>
                {word}
              </span>
            ))}
          </h1>
        </div>
      </div>
    </section>

    <section class="move-notice" aria-label="Studio move update">
      <div class="container">
        <article class="homepage-split move-notice__layout">
          <div class="move-notice__panel">
            <div class="move-notice__header">
              <h2>{moveNotice.title}</h2>
            </div>

            <div class="move-notice__copy">
              <p><span class="brand-inline-full"><span class="wordmark-inline">collabor8</span> Architecture + Design (BC)</span> is moving locations! We are saying goodbye to the Marine Building and are very excited for our new space in the Coldwell Building in the heart of the historic Gastown area of downtown Vancouver.</p>
              <p>{moveNotice.detail}</p>
            </div>

            <p class="move-notice__date">{moveNotice.date}</p>
          </div>

          <figure class="move-notice__image">
            <img
              src={gastownImage.src}
              alt={gastownImage.alt}
              width="1400"
              height="875"
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer"
            />
          </figure>
        </article>
      </div>
    </section>

    <section class="section brand-pillars">
      <div class="container">
        <div class="homepage-split brand-pillars__grid">
          <figure class="brand-pillars__image">
            <img
              src={withBase('/client-home/imagine-create-deliver.png')}
              alt="Sketch imagery representing the imagine create deliver process"
              width="2048"
              height="1536"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="brand-pillars__copy">
            {pillars.map((pillar) => (
              <article class="brand-pillars__item">
                <h2>{pillar.title}</h2>
                <p class="brand-pillars__lead">{pillar.lead}</p>
                <p>{pillar.copy}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section story-section" id="our-story">
      <div class="container">
        <div class="homepage-split story-section__grid">
          <div class="section-copy story-section__copy">
            <h2>Our Story</h2>
            <div class="story-section__body">
              <p class="lead">
                <span class="brand-inline-full"><span class="wordmark-inline">collabor8</span> Architecture + Design (BC)</span> brings together architecture and design within a single integrated practice, providing continuity and accountability from early concept through to project completion. The firm has over 35 years of continuous practice through its current and predecessor entities.
              </p>
              <p>
                Our services include pre-development and feasibility studies, planning, strategic advisory, and integrated delivery, including early contractor involvement and design-build. We provide both basic and enhanced architectural services across residential, commercial, and mixed-use sectors, including renewal and repositioning projects.
              </p>
              <p>
                We are architects and designers committed to clear thinking, purposeful design, and well-resolved outcomes. We work closely with our clients to build trust, provide direction, and bring clarity to complex projects. We are also part of an ongoing initiative to develop a library of architectural designs and delivery processes aimed at improving efficiency and cost certainty in housing.
              </p>
              <p>
                Our work is grounded in the belief that thoughtful design strengthens communities and creates enduring value socially, economically, and environmentally.
              </p>
            </div>
          </div>

          <figure class="story-section__media">
            <img
              src={withBase('/client-home/our-story.jpg')}
              alt="People gathered near a fountain in a public urban setting"
              width="1600"
              height="1200"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>
      </div>
    </section>

    <section class="section people-section" id="our-people">
      <div class="container">
        <div class="homepage-split people-section__grid">
          <figure class="people-section__media">
            <img
              src={withBase('/client-home/our-people-r1.jpeg')}
              alt="collabor8 team members outdoors together"
              width="2048"
              height="1536"
              loading="lazy"
              decoding="async"
            />
          </figure>

          <div class="section-copy people-section__copy">
            <h2>Our People</h2>
            <p class="lead">
              <span class="brand-inline-full"><span class="wordmark-inline">collabor8</span> Architecture + Design (BC)</span> is a team of architects, interior designers, and technologists with a strong track record of delivering complex projects. We maintain a disciplined, supportive work environment that enables our people to perform at a high level and produce consistent, high-quality work.
            </p>
            <p>
              We are a focused team of 12, with a balanced mix of skills and strengths capable of executing large, complex projects while remaining responsive and attentive to projects that require a more direct, one-on-one approach.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section leadership-section" id="leadership">
      <div class="container">
        <div class="homepage-split leadership-section__layout">
          <div class="leadership-section__column leadership-section__column--left">
            <div class="section-copy leadership-section__heading">
              <h2>Our Leadership</h2>
            </div>

            <div class="leadership-section__bios">
              {leadership.map((leader) => (
                <article class="leadership-card">
                  {leader.role && <p class="leadership-card__role">{leader.role}</p>}
                  <p><strong>{leader.name}</strong> {leader.copy}</p>
                </article>
              ))}
            </div>
          </div>

          <div class="leadership-section__column leadership-section__column--right">
            <figure class="leadership-section__media">
              <div class="leadership-section__image-frame">
                <img
                  src={leadershipImage.src}
                  alt={leadershipImage.alt}
                  width="3744"
                  height="2106"
                  loading="lazy"
                  decoding="async"
                />
                <span class="leadership-section__person-tag leadership-section__person-tag--jordan">Jordan Levine</span>
                <span class="leadership-section__person-tag leadership-section__person-tag--chris">Chris Block</span>
                <span class="leadership-section__person-tag leadership-section__person-tag--andre">Andre Belliveau</span>
              </div>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <section class="section section--connect" id="how-to-connect">
      <div class="container">
        <div class="connect-block">
          <div class="connect-copy">
            <h2 class="connect-title">
              Let&apos;s <span class="wordmark-inline">collabor8</span> Together
            </h2>
          </div>

          <form class="contact-form">
            <label>
              <span>First Name*</span>
              <input type="text" name="first-name" placeholder="First Name*" />
            </label>
            <label>
              <span>Last Name</span>
              <input type="text" name="last-name" placeholder="Last Name" />
            </label>
            <label class="contact-form__full">
              <span>Email*</span>
              <input type="email" name="email" placeholder="Email*" />
            </label>
            <label class="contact-form__full contact-form__message">
              <span>Message*</span>
              <textarea name="message" placeholder="Message*"></textarea>
            </label>
            <button type="button">Submit</button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer page="home" />
</Layout>
