---
interface Props {
  page?: 'home' | 'work';
}

const { page = 'home' } = Astro.props;

const footerLinks = [
  { href: page === 'home' ? '#home' : '/', label: 'Home' },
  { href: page === 'home' ? '#our-story' : '/#our-story', label: 'Who We Are' },
  { href: '/work', label: 'Our Work' },
  { href: page === 'home' ? '#how-to-connect' : '#how-to-connect', label: 'Connect' },
];

const socialLinks = [
  { href: 'https://www.instagram.com/', label: 'Instagram', icon: 'instagram' },
  { href: 'https://www.facebook.com/', label: 'Facebook', icon: 'facebook' },
  { href: 'https://www.linkedin.com/', label: 'LinkedIn', icon: 'linkedin' },
];
---

<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__panel">
      <h2 class="footer-heading footer-heading--city">Our Location</h2>
      <div class="footer-map">
        <div class="footer-map__label">73 Water Street</div>
        <iframe
          title="Map showing 73 Water Street, Vancouver"
          src="https://www.openstreetmap.org/export/embed.html?bbox=-123.10860%2C49.28310%2C-123.10300%2C49.28510&layer=mapnik&marker=49.28405%2C-123.10582"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>

    <div class="site-footer__panel site-footer__panel--contact">
      <h2 class="footer-heading footer-heading--city">Contact Us</h2>
      <ul class="footer-list">
        <li>(604) 687-3390</li>
        <li>info@c8bc.ca</li>
        <li>#300-73 Water Street</li>
        <li>Vancouver, BC V6B 1A1</li>
      </ul>
    </div>

    <div class="site-footer__panel site-footer__panel--menu">
      <h2 class="footer-heading footer-heading--city">Menu</h2>
      <ul class="footer-list footer-list--links">
        {footerLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="site-footer__panel">
      <h2 class="footer-heading footer-heading--city">Follow</h2>
      <div class="footer-social" aria-label="Social links">
        {socialLinks.map((link) => (
          <a href={link.href} class="footer-social__link" aria-label={link.label} target="_blank" rel="noreferrer">
            {link.icon === 'instagram' && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3.5" y="3.5" width="17" height="17" rx="4"></rect>
                <circle cx="12" cy="12" r="4.2"></circle>
                <circle cx="17.4" cy="6.6" r="1.1" class="footer-social__fill"></circle>
              </svg>
            )}
            {link.icon === 'facebook' && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M13.3 20.5v-7.2h2.4l.4-2.9h-2.8V8.6c0-.9.2-1.5 1.5-1.5H16V4.5c-.5-.1-1.2-.1-2.1-.1-2.1 0-3.5 1.3-3.5 3.7v2.1H8v2.9h2.3v7.2z"></path>
              </svg>
            )}
            {link.icon === 'linkedin' && (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="4" y="9" width="3.2" height="10.5" class="footer-social__fill"></rect>
                <circle cx="5.6" cy="5.8" r="1.7" class="footer-social__fill"></circle>
                <path d="M9.4 9h3.1v1.4h.1c.4-.8 1.5-1.8 3.2-1.8 3.4 0 4 2.2 4 5.2v5.7h-3.2v-5.1c0-1.2 0-2.8-1.7-2.8s-2 1.3-2 2.7v5.2H9.4z"></path>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="container site-footer__bottom">
    <div class="site-footer__signature">
      <a class="footer-brand" href={page === 'home' ? '#home' : '/'} aria-label="collabor8 home">
        <span class="footer-brand__name">collabor8</span>
        <span class="footer-brand__subtitle">Architecture + Design (BC) Ltd.</span>
      </a>

      <p class="site-footer__meta">
        <span>© 2026 <span class="wordmark-inline">collabor8</span>. All rights reserved.</span>
        <span>|</span>
        <a href="#top">Privacy Policy</a>
        <span>|</span>
        <a href="#top">Terms of Use</a>
      </p>
    </div>
  </div>
</footer>
